# --- Root / shared (copy values into app-specific `.env` files as needed) ---

# Database (PostgreSQL — matches Prisma schema)
DATABASE_URL="postgresql://adorable:adorable@localhost:5432/adorable"

# Backend (`apps/backend/.env`)
JWT_SECRET="change-me-in-production-use-long-random-string"
# 32-byte key as 64 hex characters (openssl rand -hex 32)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

OPENROUTER_API_KEY="sk-or-..."
E2B_API_KEY="e2b_..."

# Optional: deploy to Cloudflare Pages
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Browser origin(s) allowed for CORS — comma-separated for multiple (e.g. preview + prod).
# Production example (must match the browser Origin header exactly, including https://):
# FRONTEND_URL="https://adorable.fun"
# With both deployed hosts:
# FRONTEND_URL="https://adorable.fun,https://www.adorablee.fun"
FRONTEND_URL="http://localhost:3000,http://127.0.0.1:3000"

# Server port (default 3001)
# PORT=3001

# Behind a reverse proxy (nginx, Cloudflare, load balancer) — enables correct client IP for rate limits
# In production this defaults to on unless TRUST_PROXY=false
# TRUST_PROXY=true

# Next.js (`apps/web/.env.local`) — public API URL used by the browser (HTTPS in production)
# Example when API is on another host: NEXT_PUBLIC_BACKEND_URL="https://api.adorablee.fun"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"

# Optional: where the Next.js server should proxy `/api/*` (same as above unless API is on another host, e.g. Docker service name)
# BACKEND_REWRITE_URL="http://localhost:3001"

# OpenRouter attribution header — defaults to the first origin in FRONTEND_URL (or localhost in dev)
# OPENROUTER_HTTP_REFERER="https://adorablee.fun"

# Session cookie SameSite (default lax). Use none when the API is on a different site than the web app (e.g. *.railway.app); requires HTTPS.
# Production cross-site auth (frontend + backend on different domains):
# SESSION_COOKIE_SAMESITE=none

# Optional: web search / scraping (agent)
# SERPER_API_KEY=
# FIRECRAWL_API_KEY=

# Optional: max output tokens when using shared OpenRouter key
# OPENROUTER_FALLBACK_MAX_OUTPUT_TOKENS=8192
